{
  "name": "intervaltree",
  "type": "module",
  "version": "1.0.0",
  "description": "Interval tree for JavaScript",
  "author": "Jordan Baker",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npx tsup",
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest --globals --no-watch",
    "test:watch": "vitest --globals",
    "model-check": "tsx src/modelCheck.ts",
    "model-check:quick": "tsx src/modelCheck.ts 10000",
    "model-check:ci": "tsx src/modelCheck.ts 300000"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.4.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "expect": "^30.2.0",
    "fast-check": "^4.3.0",
    "pure-rand": "^7.0.1",
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
